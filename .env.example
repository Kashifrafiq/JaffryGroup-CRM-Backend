PORT=3000

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=crm_backend
DB_SYNCHRONIZE=true
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=false

JWT_SECRET=ghj
JWT_EXPIRES_IN=30d

ADMIN_EMAIL=kashif@vanestone.tech
ADMIN_PASSWORD=123K@shif

# Space name
AWS_S3_BUCKET=your-space-name

# Same region slug as in the endpoint (e.g. nyc3, ams3, sgp1)
AWS_REGION=nyc3

# Spaces → API → Spaces Keys (not your DO account password)
AWS_ACCESS_KEY_ID=your_spaces_key
AWS_SECRET_ACCESS_KEY=your_spaces_secret

# Required for DigitalOcean (not for default AWS S3). Use the regional base only — not
# https://<space-name>.nyc3.digitaloceanspaces.com (that breaks TLS / double-bucket hostnames).
S3_ENDPOINT=https://nyc3.digitaloceanspaces.com
